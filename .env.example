# ==========================================
# CIKI Dental Clinic - Environment Configuration
# ==========================================

# LINE Messaging API Configuration
# สร้าง Channel ที่ https://developers.line.biz/console/
# แล้วนำ Channel Access Token (long-lived) มาใส่
VITE_LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# LINE User ID สำหรับทดสอบ (หรือใช้ User ID ของคุณ)
# หาได้จาก LINE Developers Console > Messaging API > Your User ID
VITE_LINE_USER_ID=your_line_user_id_here

# ThaiBulkSMS Configuration (สำหรับส่ง SMS จริง)
# สมัครที่ https://www.thaibulksms.com/
SMS_API_USER=your_thaibulksms_username
SMS_API_PASS=your_thaibulksms_password
SMS_API_SENDER=CIKI

# Backend Server Configuration
PORT=3001
VITE_SERVER_URL=http://localhost:3001

# Supabase Configuration (Cloud - For Online Bookings)
VITE_SUPABASE_URL=your_supabase_cloud_url
VITE_SUPABASE_ANON_KEY=your_supabase_cloud_anon_key

# Supabase Configuration (Local - For Patient Data in Clinic)
# เครื่องลูกทั้ง 10 เครื่องจะเชื่อมต่อมาที่ IP ของเครื่องแม่
VITE_SUPABASE_LOCAL_URL=http://192.168.1.50:8000
VITE_SUPABASE_LOCAL_ANON_KEY=your_supabase_local_anon_key

# ==========================================
# Security Settings (เพิ่มใหม่)
# ==========================================

# Owner emails (comma separated) - ผู้ที่มีสิทธิ์ owner ทั้งหมด
VITE_OWNER_EMAILS=owner@dental.com,admin@dental.com

# Staff mapping format: email:role:name,email2:role2:name2
# Roles: owner, admin, dentist, assistant, receptionist
VITE_STAFF_MAPPING=doctor1@dental.com:dentist:หมอบิ๊ก,doctor2@dental.com:dentist:หมอจุ๊บ,reception1@dental.com:receptionist:สมศรี

# Session timeout settings (minutes)
VITE_SESSION_TIMEOUT=15
VITE_MAX_SESSION_DURATION=480

# ==========================================
# Application Settings
# ==========================================

VITE_APP_NAME=Ciki Dental Clinic
VITE_APP_VERSION=1.0.0
VITE_API_TIMEOUT=30000

# ==========================================
# Feature Flags
# ==========================================

VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_SMS=false
VITE_ENABLE_LINE=true

# ==========================================
# Backup Settings
# ==========================================

VITE_AUTO_BACKUP=true
VITE_BACKUP_INTERVAL=daily
VITE_BACKUP_RETENTION_DAYS=30

# ==========================================
# Performance Settings
# ==========================================

VITE_CACHE_DURATION=300000
VITE_PAGINATION_PAGE_SIZE=50
VITE_MAX_UPLOAD_SIZE=10485760
