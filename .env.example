# ==========================================
# CIKI Dental Clinic - Environment Configuration
# ==========================================

# LINE Messaging API Configuration
# สร้าง Channel ที่ https://developers.line.biz/console/
# แล้วนำ Channel Access Token (long-lived) มาใส่
VITE_LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# LINE User ID สำหรับทดสอบ (หรือใช้ User ID ของคุณ)
# หาได้จาก LINE Developers Console > Messaging API > Your User ID
VITE_LINE_USER_ID=your_line_user_id_here

# ThaiBulkSMS Configuration (สำหรับส่ง SMS จริง)
# สมัครที่ https://www.thaibulksms.com/
SMS_API_USER=your_thaibulksms_username
SMS_API_PASS=your_thaibulksms_password
SMS_API_SENDER=CIKI

# Backend Server Port
PORT=3001

# Supabase Configuration (ถ้ามี)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
